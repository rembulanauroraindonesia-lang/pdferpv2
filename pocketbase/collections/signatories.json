{
  "name": "signatories",
  "type": "base",
  "schema": [
    {
      "name": "name",
      "type": "text",
      "required": true,
      "options": { "maxSize": 100 }
    },
    {
      "name": "role",
      "type": "text",
      "required": true,
      "options": { "maxSize": 50 }
    },
    {
      "name": "is_active",
      "type": "bool",
      "required": false,
      "options": {}
    },
    {
      "name": "signature_file",
      "type": "file",
