      "options": {
        "maxSelect": 1,
        "maxSize": 5242880,
        "mimeTypes": ["image/png", "image/jpeg", "image/svg+xml"]
      }
    }
  ],
  "indexes": [
    "CREATE INDEX idx_signatories_role ON signatories (role)",
    "CREATE INDEX idx_signatories_active ON signatories (is_active)"
  ],
  "listRule": "",
  "viewRule": "",
  "createRule": "",
  "updateRule": "",
  "deleteRule": ""
